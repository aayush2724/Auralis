# ─────────────────────────────────────────────
#  Auralis — Environment Variables Template
# ─────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=auralis
POSTGRES_USER=auralis
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://auralis:changeme@localhost:5432/auralis

# Redis
REDIS_URL=redis://localhost:6379/0

# Vector Store
VECTORSTORE_PATH=vectorstore/

# Embedding model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM settings
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# API
API_HOST=0.0.0.0
API_PORT=8000

# Auth (JWT)
JWT_SECRET_KEY=replace_with_a_long_random_secret_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Default admin user seeded on first startup
ADMIN_EMAIL=admin@auralis.ai
ADMIN_PASSWORD=changeme
